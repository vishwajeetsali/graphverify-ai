# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (.env)
# Copy this file to .env and fill in local values.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB — local dev
MONGO_URI=mongodb://localhost:27017/graphverify

# JWT — use a long random string (min 32 chars)
JWT_SECRET=replace_with_long_random_string_min_32_chars

# Python FastAPI service — local dev
PYTHON_SERVICE_URL=http://localhost:8000

# Ollama (local LLM — no API key needed, runs on your machine)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# Server
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# RENDER PRODUCTION — set ALL of the following in Render Dashboard > Environment
# (DO NOT rely on the .env file above for production — Render reads these directly)
# ─────────────────────────────────────────────────────────────────────────────

# MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/graphverify?retryWrites=true&w=majority
# JWT_SECRET=<long_random_secret_different_from_dev>
# PYTHON_SERVICE_URL=https://<your-hf-username>-graphverify-ai-space.hf.space
# NODE_ENV=production
# PORT=5000

# WebAuthn — CRITICAL: must match your Vercel deployment domain exactly
# FRONTEND_URL=https://<your-app>.vercel.app
# RP_ID=<your-app>.vercel.app

# Ollama is NOT available on Render — omit OLLAMA_HOST to use template fallback